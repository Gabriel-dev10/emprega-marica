{
  "name": "saas-emprego",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -b && bunx --bun vite build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "preview": "bunx --bun vite preview",
    "tsc": "tsc -b",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test src",
    "test:watch": "bun test --watch src",
    "test:e2e": "playwright test",
    "coverage": "bun test --coverage src",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "lighthouse": "bun run build && concurrently -k -s first \"bun run preview -- --port 4173 --strictPort\" \"wait-on http://localhost:4173 && lighthouse http://localhost:4173 --view --preset=desktop --output-path ./reports/lighthouse.html\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.10.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@happy-dom/global-registrator": "^20.7.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "lighthouse": "^13.0.1",
    "storybook": "^10.1.8",
    "typescript": "~5.9.3",
    "vite": "7.2.7",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "vite": "7.2.7",
    "rollup": "^4.0.0"
  }
}
